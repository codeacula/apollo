# Apollo reverse proxy
#
# Dev default: http://0.0.0.0:8083
# Production: set CADDY_HTTP_PORT/CADDY_HTTPS_PORT to 80/443 in .env.
# Caddy handles ACME/Let's Encrypt automatically when a real domain is used.

:{$CADDY_HTTP_PORT:8083} {
  # Main API + SPA
  reverse_proxy apollo-api:5144

  # Discord service endpoints (exposed under /discord/)
  handle /discord/* {
    uri strip_prefix /discord
    reverse_proxy apollo-discord:5145
  }
}
