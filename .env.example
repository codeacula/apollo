# Infrastructure Configuration
# These variables are required for local development and Docker deployment.
# Application configuration (AI, Discord, SuperAdmin) is now stored in the database
# and must be set through the system initialization wizard at first startup.

# PostgreSQL Database Configuration
POSTGRES_USER=apollo
POSTGRES_PASSWORD=apollo
POSTGRES_DB=apollo_db

# Database Connection Strings
# For Docker: use 'pgsql' as host (service name from compose.yaml)
# For local development: use 'localhost'
ConnectionStrings__Apollo="Host=pgsql;Database=apollo_db;Username=apollo;Password=apollo"
ConnectionStrings__Redis="redis,password=apollo_redis"
ConnectionStrings__Quartz="Host=pgsql;Database=apollo_db;Username=apollo;Password=apollo"

# gRPC Service Configuration
# Defines how to connect to the Apollo.Service gRPC backend
GrpcHostConfig__Host="localhost"
GrpcHostConfig__Port="5270"
GrpcHostConfig__ApiToken="this_is_a_sample_token"
GrpcHostConfig__ValidateSslCertificate=false
GrpcHostConfig__UseHttps=false
